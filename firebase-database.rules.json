        ".write": "auth != null && (((!data.exists()) && root.child('teacherSessions').child(auth.uid).child('teacherId').exists() && newData.child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()) || (data.exists() && (((data.child('meta/ownerTeacherId').exists() && data.child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.child('meta/ownerTeacherId').exists() && data.child('meta/ownerUid').val() === auth.uid))))",
        "meta": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "board": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "links": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "timer": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "screen": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "announcement": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "summary": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "events": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))"
        },
        "members": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))",
          "$memberId": {
            ".read": "auth != null && (auth.uid === $memberId || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()))",
            ".write": "auth != null && ((auth.uid === $memberId && (data.parent().parent().child('meta/visibility').val() === 'public' || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()) || data.parent().child(auth.uid).exists() || newData.child('inviteCodeUsed').val() === data.parent().parent().child('meta/inviteCode').val())) || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()))"
          }
        },
        "attendance": {
          ".write": "auth != null && (((data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val())) || (!data.parent().child('meta/ownerTeacherId').exists() && data.parent().child('meta/ownerUid').val() === auth.uid))",
          "$memberId": {
            ".read": "auth != null && (auth.uid === $memberId || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()))",
            ".write": "auth != null && ((auth.uid === $memberId && (data.parent().parent().child('meta/visibility').val() === 'public' || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()) || data.parent().parent().child('members').child(auth.uid).exists() || newData.child('inviteCodeUsed').val() === data.parent().parent().child('meta/inviteCode').val())) || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()))"
          }
        },
        "signals": {
          "$memberId": {
            ".read": "auth != null && (auth.uid === $memberId || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()))",
            ".write": "auth != null && ((auth.uid === $memberId && (data.parent().parent().child('meta/visibility').val() === 'public' || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()) || data.parent().parent().child('members').child(auth.uid).exists())) || data.parent().parent().child('meta/ownerUid').val() === auth.uid || (data.parent().parent().child('meta/ownerTeacherId').exists() && data.parent().parent().child('meta/ownerTeacherId').val() === root.child('teacherSessions').child(auth.uid).child('teacherId').val()))"
          }
        }
      }
    }
  }
}
